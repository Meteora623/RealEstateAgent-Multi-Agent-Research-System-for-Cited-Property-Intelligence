APP_NAME=realestate-agent
ENV=dev
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=realestate-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

PINECONE_API_KEY=
PINECONE_INDEX_NAME=realestate-agent-index
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

COHERE_API_KEY=

USE_PINECONE=false
USE_COHERE_RERANKER=false
DEFAULT_RETRIEVAL_MODE=hybrid
DEFAULT_TOP_K=8
DEFAULT_CANDIDATE_POOL_MULTIPLIER=4
FUSION_ALPHA=0.65
RERANK_TOP_N=20
CHUNK_SIZE=700
CHUNK_OVERLAP=120
SEMANTIC_CHUNKING=false
CHUNKING_STRATEGY=fixed
TOOL_IO_LATENCY_MS=35

DATA_DIR=data
INDICES_DIR=data/indices
EVAL_OUTPUT_DIR=artifacts/eval
REPORTS_DIR=reports

DATASET_PROFILE=benchmark
BENCHMARK_NUM_PROPERTIES=780
BENCHMARK_DOCS_PER_PROPERTY=6
BENCHMARK_EVAL_QUERIES=80
BENCHMARK_SEED=13

RAGAS_MODE=auto
RAGAS_FALLBACK_ENABLED=true
REQUIRE_OFFICIAL_RAGAS_BEST_CONFIG=true
